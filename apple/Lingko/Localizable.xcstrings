    "Are you sure you want to delete '%@'? This will remove the tag from all translations." : {
      "comment" : "A message in an alert that asks the user to confirm they want to delete a specific tag. The argument is the name of the tag that is about to be deleted.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "متأكد من حذف \"%@\"؟ سيزيل ذلك التصنيف من جميع الترجمات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie '%@' wirklich löschen? Dies entfernt das Tag aus allen Übersetzungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres eliminar '%@'? Esto eliminará la etiqueta de todas las traducciones."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удалить «%@»? Тег будет удалён из всех переводов."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定要删除“%@”吗？这将从所有翻译中移除该标签。"
          }
        }
      }
    },
    "Are you sure you want to delete all translation history? This action cannot be undone." : {
      "comment" : "A message displayed when the user attempts to clear all translation history.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف سجل الترجمة بالكامل؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie wirklich den gesamten Übersetzungsverlauf löschen? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres eliminar todo el historial de traducciones? Esta acción no se puede deshacer."
