    "All translations and data processing happen entirely on your device. No data is ever sent to external servers." : {
      "comment" : "A description of the privacy policy, emphasizing that all data is stored locally on the user's device.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع الترجمات تُعالَج بالكامل على جهازك. لا تُرسَل أي بيانات إلى جهات خارجية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Übersetzungen und Datenverarbeitung erfolgen vollständig auf Ihrem Gerät. Es werden niemals Daten an externe Server gesendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas las traducciones y el procesamiento de datos ocurren completamente en tu dispositivo. Nunca se envía ningún dato a servidores externos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все переводы и обработка данных выполняются полностью на вашем устройстве. Данные никогда не отправляются на внешние серверы."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有翻译和数据处理完全在您的设备上进行。不会发送任何数据到外部服务器。"
          }
        }
      }
    },
